---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,600&family=Outfit:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>

<section class="bg-green-50 py-24 px-6 text-black overflow-hidden">
  <div class="max-w-5xl mx-auto">

    <!-- ── Section Header ── -->
    <div class="text-center mb-20">
      <span class="inline-block text-[10px] tracking-[0.22em] uppercase text-white bg-secondary border border-secondary px-4 py-2 rounded-full mb-6">
        The Process
      </span>
      <h2 class="font-['Cormorant_Garamond',serif] text-5xl md:text-6xl font-semibold leading-tight mb-5 text-black">
        How We Work <em class="italic text-primary">Together</em>
      </h2>
      <p class="text-black text-base font-light leading-relaxed max-w-md mx-auto">
        From first conversation to long-term growth — a clear, structured journey designed around your success.
      </p>
    </div>

    <!-- ── Steps ── -->
    <ol class="relative flex flex-col gap-5">

      <!-- Vertical connector line -->
      <div
        class="absolute left-[27px] top-7 bottom-7 w-px bg-gradient-to-b from-emerald-400/70 via-primary/60 to-transparent pointer-events-none"
        aria-hidden="true"
      ></div>

      {steps.map((step, i) => (
        <li
          class="group flex items-start gap-5 step-item"
          style={`animation-delay: ${i * 90}ms`}
        >
          <!-- Marker -->
          <div
            class={[
              "relative z-10 flex-shrink-0 w-[54px] h-[54px] rounded-full flex items-center justify-center border transition-all duration-300",
              step.accent
                ? "bg-secondary border-secondary shadow-[0_0_28px_rgba(52,211,153,0.45)]"
                : "bg-primary border-primary",
            ].join(" ")}
          >
            <span
              class={[
                "text-[11px] font-medium tracking-wider",
                step.accent ? "text-white" : "text-white",
              ].join(" ")}
            >
              {step.number}
            </span>
            <!-- Ripple ring -->
            <span class="absolute inset-[-6px] rounded-full border border-emerald-400/0 group-hover:border-emerald-400/20 transition-all duration-500 group-hover:scale-110 pointer-events-none"></span>
          </div>

          <!-- Card -->
          <div
            class={[
              "flex-1 rounded-2xl border p-6 transition-all duration-300",
              step.accent
                ? "bg-primary shadow-[0_8px_40px_rgba(52,211,153,0.2)]"
                : "bg-white border-green-500",
            ].join(" ")}
          >
            <div class="flex flex-col lg:flex-row items-start gap-4">

              <!-- Icon -->
              <div
                class={[
                  "flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center mt-0.5",
                  step.accent ? "bg-white text-black" : "bg-secondary text-white",
                ].join(" ")}
              >
                <Fragment set:html={step.icon} />
              </div>

              <!-- Text body -->
              <div class="flex-1 min-w-0">

                <!-- Tag -->
                <span
                  class={[
                    "inline-block text-[9px] tracking-[0.18em] uppercase px-2.5 py-1 rounded-full mb-2.5",
                    step.accent
                      ? "bg-white text-black font-bold"
                      : "bg-primary text-white",
                  ].join(" ")}
                >
                  {step.tag}
                </span>

                <!-- Title -->
                <h3
                  class={[
                    "text-2xl font-semibold mb-2 leading-tight",
                    step.accent ? "text-white" : "text-black",
                  ].join(" ")}
                >
                  {step.title}
                </h3>

                <!-- Description -->
                <p
                  class={[
                    "text-sm leading-relaxed mb-3 font-light",
                    step.accent ? "text-white" : "text-black",
                  ].join(" ")}
                >
                  {step.description}
                </p>

                <!-- Meta pills -->
                <div class="flex flex-wrap gap-2">
                  {step.meta.map((m) => (
                    <span
                      class={[
                        "text-[10px] tracking-wide px-2.5 py-1 rounded-lg",
                        step.accent
                          ? "bg-white text-black"
                          : "bg-primary text-white",
                      ].join(" ")}
                    >
                      {m}
                    </span>
                  ))}
                </div>

              </div>
            </div>
          </div>
        </li>
      ))}
    </ol>

    <!-- ── CTA ── -->
    <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/premium"
        class="inline-flex items-center gap-2 bg-primary text-white font-medium text-sm px-7 py-3.5 rounded-full transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_28px_rgba(52,211,153,0.35)] active:translate-y-0"
      >
        Book Your Discovery Call
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
        </svg>
      </a>
      <span class="text-[11px] text-black tracking-widest uppercase">
        Free · No obligation · 30 min
      </span>
    </div>

  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .step-item {
    opacity: 0;
    animation: fadeUp 0.45s ease forwards;
  }
</style>