---
import Button from "./ui/Button.astro";
import HeroIMG from "../assets/images/hero-recruitment.jpeg";
import { Image } from "astro:assets";
---

<section
  class="relative bg-gradient-to-b from-[#020617] via-[#0f172a] to-black text-white overflow-hidden"
>
  {/* Glow effect */}
  <div
    class="absolute top-[-100px] left-[-100px] w-[400px] h-[400px] bg-green-500/20 rounded-full blur-[120px]"
  >
  </div>

  <div
    class="max-w-7xl mx-auto px-6 py-24 md:py-32 grid md:grid-cols-2 gap-12 items-center"
  >
    {/* LEFT CONTENT */}
    <div>
      <p class="text-green-400 font-medium mb-3">
        Recruitment Made Predictable
      </p>

      <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
        Stop <span
          class="bg-gradient-to-br from-primary via-white to-primary text-transparent bg-clip-text"
          >Gambling</span
        >. <br /> Start Hiring Right.
      </h1>

      <p class="text-lg text-gray-300 max-w-xl mb-8">
        Get predictable, professional recruitment execution every month.
        <!-- Get consistent, high-quality talent every month with a recruitment
        system designed for scaling teams. -->
      </p>

      <div class="flex gap-4 flex-wrap mb-8">
        <Button href="/services" variant="primary">Get Started</Button>
        <Button href="https://calendly.com/info-bmeson" target="_blank" variant="border">Request a Call</Button> 
      </div>

      {/* Trust indicators */}
      <div class="flex flex-wrap gap-6 text-sm text-gray-400">
        <span>✔ 100+ hires</span>
        <span>✔ 95% retention</span>
        <span>✔ Startup trusted</span>
      </div>
    </div>

    {/* RIGHT VISUAL */}
    <div class="relative">
      <Image
        src={HeroIMG}
        alt="Recruitment meeting"
        class="rounded-2xl shadow-2xl"
      />
      
      {/* Floating badge */}
      <div
        class="absolute -top-5 -right-5 bg-white text-black text-sm px-4 py-2 rounded-full shadow-lg"
      >
        ⭐ Trusted by 120+ companies
      </div>
    </div>
  </div>
</section>

