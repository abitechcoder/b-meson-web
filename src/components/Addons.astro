---
const addOns = [
  {
    title: "Assessment & Testing",
    price: "₦50k per role",
    features: ["Psychometric assessments", "Skills testing", "Case studies or work simulations"],
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    title: "Employer Branding Content",
    price: "₦200k per project",
    features: ["Job ad copywriting", "Career page content", "Employee value proposition (EVP)"],
    icon: "M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"
  },
  {
    title: "Recruitment Marketing",
    price: "₦500k per campaign",
    features: ["Targeted sourcing for hard-to-fill roles", "LinkedIn & social media advertising", "University or community events"],
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    title: "ATS or Dashboard Setup",
    price: "₦600k setup + ₦70k/mo",
    features: ["Custom candidate tracking system", "Real-time hiring dashboard", "Integration with HR tools"],
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
  },
  {
    title: "Hiring Manager Training",
    price: "₦200k per session",
    features: ["Interview skills workshop", "Unconscious bias training", "Structured hiring best practices"],
    icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
  }
];
---

<section class="max-w-6xl mx-auto py-16 px-4">
  <div class="text-center mb-12">
    <h2 class="text-3xl font-bold text-slate-900">Optional Add-ons</h2>
    <p class="text-slate-500 mt-2 text-lg">Enhance your recruitment strategy with targeted expertise</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {addOns.map((item) => (
      <div class="group bg-white border border-gray-200 rounded-2xl p-6 hover:border-green-500 transition-all duration-300 shadow-sm hover:shadow-md flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="p-2 bg-green-50 rounded-lg group-hover:bg-green-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-lg text-slate-800 leading-tight">{item.title}</h3>
          </div>

          <ul class="space-y-3 mb-6">
            {item.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-slate-600 leading-snug">
                <span>•</span>
                {feature}
              </li>
            ))}
          </ul>
        </div>

        <div class="pt-4 border-t border-gray-100 flex items-center gap-2">
          <span class="text-xs uppercase tracking-wider font-bold text-gray-500">Price:</span>
          <span class="text-md font-bold text-black">{item.price}</span>
        </div>
      </div>
    ))}
  </div>
</section>