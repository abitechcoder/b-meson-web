---
const clientPoints = [
  {
    title: "Clients Are Partners, Not Bosses",
    description:
      "We collaborate as strategic partners, aligning with your business goals to deliver long-term hiring success."
  },
  {
    title: "We Serve Growth-Minded Companies",
    description:
      "We work best with organizations that are scaling, evolving, and committed to building high-performing teams."
  },
  {
    title: "We Augment HR, We Do Not Replace It",
    description:
      "Our role is to strengthen your HR capabilities with specialized recruitment expertise, not take them over."
  },
  {
    title: "We Reject Bad-Fit Clients",
    description:
      "We maintain high standards and decline engagements that don’t align with our process, values, or expectations."
  }
];

const candidatePoints = [
  {
    title: "Candidates Are Professionals, Not Commodities",
    description:
      "We treat every candidate with respect, transparency, and professionalism throughout the hiring journey."
  },
  {
    title: "Candidates Are Market Intelligence",
    description:
      "Each interaction helps us gather insights into talent trends, expectations, and market dynamics."
  },
  {
    title: "We Pre-Vet for Quality",
    description:
      "We rigorously assess skills, experience, and culture fit before presenting candidates to clients."
  },
  {
    title: "We Build Long-Term Talent Relationships",
    description:
      "We invest in lasting connections with talent, not just one-off placements."
  }
];
---

<section class="py-16 md:py-24 bg-green-100">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        Our Philosophy
      </h2>
      <p class="mt-4 text-gray-600 text-lg">
        How we approach our relationships with clients and candidates defines the quality of outcomes we deliver.
      </p>
    </div>

    <!-- Grid Layout -->
    <div class="grid md:grid-cols-2 gap-10">
      
      <!-- Clients Column -->
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <h3 class="text-xl md:text-2xl text-center md:text-left font-semibold text-gray-900 mb-6">
          How We View Clients
        </h3>
        <ul class="space-y-6">
          {clientPoints.map((item) => (
            <li class="flex gap-4">
              <div class="mt-2 w-2.5 h-2.5 bg-secondary rounded-full flex-shrink-0"></div>
              <div>
                <h4 class="font-semibold text-gray-800">{item.title}</h4>
                <p class="text-gray-600 text-sm mt-1">
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Candidates Column -->
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <h3 class="text-xl md:text-2xl text-center md:text-left font-semibold text-gray-900 mb-6">
          How We View Candidates
        </h3>
        <ul class="space-y-6">
          {candidatePoints.map((item) => (
            <li class="flex gap-4">
              <div class="mt-2 w-2.5 h-2.5 bg-primary rounded-full flex-shrink-0"></div>
              <div>
                <h4 class="font-semibold text-gray-800">{item.title}</h4>
                <p class="text-gray-600 text-sm mt-1">
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>