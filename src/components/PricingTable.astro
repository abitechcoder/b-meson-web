---
const plans = [
  {
    name: "Support Plan",
    price: "₦250k/month",
    commitment: "3 months",
    roles: "Up to 2",
    intelligence: "Basic",
    advisory: "Basic",
    sourcing: true,
    talentPool: false,
    recruiter: false,
    optimization: false,
    sla: false,
    reporting: "Weekly email",
    bestFor: "20-50 employees",
    ctaText: "Get Started",
    link: "/checkout?plan=support-plan"
  },
  {
    name: "Growth Plan",
    price: "₦500k/month",
    commitment: "3–6 months",
    roles: "Up to 4",
    intelligence: "Detailed",
    advisory: "Bi-weekly",
    sourcing: true,
    talentPool: true,
    recruiter: true,
    optimization: true,
    sla: false,
    reporting: "Weekly + Monthly dashboard",
    bestFor: "50-150 employees",
    ctaText: "Get Started",
    link: "/checkout?plan=growth-plan",
    highlight: true, // Used to make this plan pop
  },
  {
    name: "Embedded Partner",
    price: "₦1M/month",
    commitment: "6 months",
    roles: "Unlimited (fair use: 5–8)",
    intelligence: "Comprehensive",
    advisory: "Continuous",
    sourcing: true,
    talentPool: "Priority Access",
    recruiter: "Embedded",
    optimization: "Full Audit",
    sla: true,
    reporting: "Executive-level monthly",
    bestFor: "100-300 employees",
    ctaText: "Get Started",
    link: "/checkout?plan=embedded-partner",
  },
];
---

<div class="py-12 bg-gray-50 px-4">
  <div class="max-w-6xl mx-auto overflow-x-auto">
    <table class="w-full text-left border-collapse bg-white shadow-sm rounded-xl overflow-hidden">
      <thead>
        <tr class="bg-primary text-white">
          <th class="p-5 text-sm font-semibold uppercase tracking-wider">Feature</th>
          {plans.map((plan) => (
            <th class={`p-5 text-center ${plan.highlight ? 'bg-secondary' : ''}`}>
              <div class="text-lg font-bold">{plan.name}</div>
              <div class="text-sm font-normal opacity-90">{plan.price}</div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <tr>
          <td class="p-5 font-medium text-gray-700">Commitment</td>
          {plans.map((plan) => <td class="p-5 text-center text-gray-600">{plan.commitment}</td>)}
        </tr>
        
        <tr class="bg-gray-50/50">
          <td class="p-5 font-medium text-gray-700">Active Roles</td>
          {plans.map((plan) => <td class="p-5 text-center text-gray-600">{plan.roles}</td>)}
        </tr>

        <tr>
          <td class="p-5 font-medium text-gray-700">Sourcing & Screening</td>
          {plans.map((plan) => (
            <td class="p-5 text-center text-green-600 font-bold text-xl">✓</td>
          ))}
        </tr>

        <tr class="bg-gray-50/50">
          <td class="p-5 font-medium text-gray-700">Market Intelligence</td>
          {plans.map((plan) => <td class="p-5 text-center text-gray-600">{plan.intelligence}</td>)}
        </tr>

        <tr>
          <td class="p-5 font-medium text-gray-700">Talent Pool Building</td>
          {plans.map((plan) => (
            <td class="p-5 text-center">
              {plan.talentPool === "Priority Access" ? (
                <span class="text-indigo-600 font-semibold italic">✓✓ (Priority Access)</span>
              ) : plan.talentPool ? (
                <span class="text-green-600 font-bold text-xl">✓</span>
              ) : (
                <span class="text-gray-600 text-xl">✗</span>
              )}
            </td>
          ))}
        </tr>

        <tr class="bg-gray-50/50">
          <td class="p-5 font-medium text-gray-700">Strategic Advisory</td>
          {plans.map((plan) => <td class="p-5 text-center text-gray-600">{plan.advisory}</td>)}
        </tr>

        <tr>
          <td class="p-5 font-medium text-gray-700">Dedicated Recruiter</td>
          {plans.map((plan) => (
            <td class="p-5 text-center text-gray-600">
              {plan.recruiter === "Embedded" ? <span class="text-indigo-600 font-semibold italic">✓✓ (Embedded)</span> : plan.recruiter ? <span class="text-green-600 text-xl font-semibold italic">✓</span> : "✗"}
            </td>
          ))}
        </tr>

        <tr class="bg-gray-50/50">
          <td class="p-5 font-medium text-gray-700">Process Optimization</td>
          {plans.map((plan) => (
            <td class="p-5 text-center text-gray-600">
              {plan.optimization === "Full Audit" ? <span class="text-indigo-600 font-semibold italic">✓✓ (Full Audit)</span> : plan.optimization ? <span class="text-green-600 text-xl font-semibold italic">✓</span> : "✗"}
            </td>
          ))}
        </tr>

        <tr>
          <td class="p-5 font-medium text-gray-700">SLA-Based Delivery</td>
          {plans.map((plan) => (
            <td class="p-5 text-center">
              {plan.sla ? <span class="text-green-600 font-bold text-xl">✓</span> : <span class="text-gray-600 text-xl">✗</span>}
            </td>
          ))}
        </tr>

        <tr class="bg-gray-50/50">
          <td class="p-5 font-medium text-gray-700">Reporting</td>
          {plans.map((plan) => <td class="p-5 text-center text-gray-600">{plan.reporting}</td>)}
        </tr>

        <tr>
          <td class="p-5 font-medium text-gray-700">Best For</td>
          {plans.map((plan) => <td class="p-5 text-center text-gray-600">{plan.bestFor}</td>)}
        </tr>
      </tbody>
      <tfoot>
        <tr class="bg-gray-50/30">
          <td class="p-6"></td>
          {plans.map((plan) => (
            <td class="p-6 text-center">
              <a 
                href={plan.link}
                class={`inline-block w-full py-3 px-4 rounded-lg font-bold transition-all duration-200 text-center
                  ${plan.highlight 
                    ? 'bg-secondary text-white hover:bg-primary'
                    : 'bg-primary text-white hover:bg-secondary'
                  }`}
              >
                {plan.ctaText}
              </a>
            </td>
          ))}
        </tr>
      </tfoot>
    </table>
  </div>
</div>
