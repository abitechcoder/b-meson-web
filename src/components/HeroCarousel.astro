---
import { Image } from "astro:assets";

import operationsImg from "../assets/images/operations.jpeg";
import readinessImg from "../assets/images/readiness.jpeg";
import timeImg from "../assets/images/time.jpeg";

const slides = [
  {
    title: "Recruitment Is Operations, Not Magic",
    description:
      "Good hiring outcomes come from disciplined processes, not luck. We track, measure, and optimize everything we do",
    image: operationsImg,
  },
  {
    title: "Readiness Has Value",
    description:
      "Companies pay lawyers monthly even without lawsuits. Hiring readiness prevents costly delays and panic decisions",
    image: readinessImg,
  },
  {
    title: "Quality Recruitment Takes Time",
    description:
      "Rushing always reduces quality. We educate clients on realistic hiring timelines for their market",
    image: timeImg,
  },
];
---

<section class="relative w-full h-[60vh] md:h-[70vh] overflow-hidden text-white">
  <!-- Slides Wrapper -->
  <div id="carousel" class="relative h-full w-full">
    {slides.map((slide, index) => (
      <div
        class={`slide absolute inset-0 transition-opacity duration-700 ease-in-out ${
          index === 0 ? "opacity-100 z-20" : "opacity-0 z-10"
        }`}
        data-index={index}
      >
        <!-- Background Image -->
        <Image
          src={slide.image}
          alt={slide.title}
          width={1200}
          height={800}
          class="absolute inset-0 object-cover object-center h-full w-full"
        />

        <!-- Dark overlay for readability -->
        <div class="absolute inset-0 bg-black/80"></div>

        <!-- Content -->
        <div class="relative z-30 h-full flex items-center justify-center px-6 text-center">
          <div class="max-w-3xl">
            <h1 class="text-2xl sm:text-3xl md:text-5xl font-bold leading-tight mb-4 animate-fadeUp">
              {slide.title}
            </h1>
            <p class="text-sm sm:text-base md:text-lg text-gray-200 animate-fadeUp delay-150">
              {slide.description}
            </p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Navigation Dots -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-3 z-40">
    {slides.map((_, i) => (
      <button
        class="dot w-3 h-3 rounded-full bg-white/40 hover:bg-white/80 transition"
        data-dot={i}
        aria-label={`Go to slide ${i + 1}`}
      ></button>
    ))}
  </div>
</section>

<script>
  const slides = document.querySelectorAll(".slide") as NodeListOf<HTMLElement>;
  const dots = document.querySelectorAll(".dot") as NodeListOf<HTMLElement>;

  let current = 0;
  let interval = null;

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.style.opacity = i === index ? "1" : "0";
      slide.style.zIndex = i === index ? "20" : "10";
    });

    dots.forEach((dot, i) => {
      dot.classList.toggle("bg-white", i === index);
      dot.classList.toggle("bg-white/40", i !== index);
    });

    current = index;
  }

  function nextSlide() {
    let next = (current + 1) % slides.length;
    showSlide(next);
  }

  function startAutoRotate() {
    interval = setInterval(nextSlide, 5000);
  }

  function stopAutoRotate() {
    clearInterval(interval);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      showSlide(i);
      stopAutoRotate();
      startAutoRotate();
    });
  });

  showSlide(0);
  startAutoRotate();
</script>

<style>
  .animate-fadeUp {
    animation: fadeUp 0.8s ease forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>